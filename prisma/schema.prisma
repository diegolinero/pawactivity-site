generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
}

enum DeviceStatus {
  inactive
  active
  assigned
}

enum PetSex {
  male
  female
  unknown
}

enum ActivityType {
  rest
  walk
  run
}

enum SyncLogStatus {
  success
  failed
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  email        String          @unique @db.VarChar(255)
  passwordHash String          @map("password_hash")
  firstName    String          @map("first_name") @db.VarChar(100)
  lastName     String?         @map("last_name") @db.VarChar(100)
  timezone     String          @default("UTC") @db.VarChar(100)
  status       UserStatus      @default(active)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  lastLoginAt  DateTime?       @map("last_login_at")
  sessions     AuthSession[]
  resets       PasswordReset[]
  pets         Pet[]
  devices      Device[]
  syncLogs     SyncLog[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceName       String?   @map("device_name") @db.VarChar(120)
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Pet {
  id             String                 @id @default(uuid()) @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  name           String                 @db.VarChar(120)
  breed          String?                @db.VarChar(120)
  birthDate      DateTime?              @map("birth_date") @db.Date
  weightKg       Decimal?               @map("weight_kg") @db.Decimal(5, 2)
  sex            PetSex                 @default(unknown)
  photoUrl       String?                @map("photo_url")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices        PetDevice[]
  activityEvents ActivityEvent[]
  dailySummaries ActivityDailySummary[]
  syncLogs       SyncLog[]

  @@index([userId])
  @@map("pets")
}

model Device {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String?      @map("user_id") @db.Uuid
  serialNumber    String       @unique @map("serial_number") @db.VarChar(120)
  model           String       @db.VarChar(80)
  firmwareVersion String?      @map("firmware_version") @db.VarChar(50)
  status          DeviceStatus @default(inactive)
  batteryLevel    Int?         @map("battery_level")
  lastSeenAt      DateTime?    @map("last_seen_at")
  activatedAt     DateTime?    @map("activated_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  pets            PetDevice[]
  activityEvents  ActivityEvent[]
  syncLogs        SyncLog[]

  @@index([userId])
  @@map("devices")
}

model PetDevice {
  id           String    @id @default(uuid()) @db.Uuid
  petId        String    @map("pet_id") @db.Uuid
  deviceId     String    @map("device_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")
  isActive     Boolean   @default(true) @map("is_active")
  pet          Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([deviceId])
  @@map("pet_devices")
}

model ActivityEvent {
  id              String       @id @default(uuid()) @db.Uuid
  petId           String       @map("pet_id") @db.Uuid
  deviceId        String       @map("device_id") @db.Uuid
  activityType    ActivityType @map("activity_type")
  startedAt       DateTime     @map("started_at")
  endedAt         DateTime     @map("ended_at")
  durationSeconds Int          @map("duration_seconds")
  confidence      Decimal?     @db.Decimal(4, 3)
  recordedAt      DateTime     @default(now()) @map("recorded_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  device          Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([petId, startedAt(sort: Desc)])
  @@index([deviceId, startedAt(sort: Desc)])
  @@map("activity_events")
}

model ActivityDailySummary {
  id                 String   @id @default(uuid()) @db.Uuid
  petId              String   @map("pet_id") @db.Uuid
  summaryDate        DateTime @map("summary_date") @db.Date
  timezone           String   @db.VarChar(100)
  restSeconds        Int      @default(0) @map("rest_seconds")
  walkSeconds        Int      @default(0) @map("walk_seconds")
  runSeconds         Int      @default(0) @map("run_seconds")
  totalActiveSeconds Int      @default(0) @map("total_active_seconds")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  pet                Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, summaryDate])
  @@index([petId, summaryDate(sort: Desc)])
  @@map("activity_daily_summaries")
}

model SyncLog {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  petId           String        @map("pet_id") @db.Uuid
  deviceId        String        @map("device_id") @db.Uuid
  generatedAt     DateTime      @map("generated_at")
  timezone        String        @db.VarChar(100)
  recordsReceived Int           @default(0) @map("records_received")
  status          SyncLogStatus @default(success)
  syncedAt        DateTime      @default(now()) @map("synced_at")
  errorMessage    String?       @map("error_message")
  createdAt       DateTime      @default(now()) @map("created_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet             Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  device          Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId, syncedAt(sort: Desc)])
  @@index([petId, syncedAt(sort: Desc)])
  @@map("sync_logs")
}
